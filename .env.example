# Ejemplo de variables de entorno para ODMGR
APP_PREFIX=odmgr
APP_PORT=8000
NGINX_PORT=80
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=opendatamanager

# Límites de recursos del contenedor backend
# APP_MEMORY_LIMIT=4g       # memoria máxima (Docker hard limit)
# APP_MEMORY_RESERVATION=512m  # memoria reservada (soft limit)
# APP_CPU_LIMIT=2.0         # CPUs máximos
