# Variables de entorno para produccion ODMGR
# Copia este archivo fuera del repo como .env.production y rellena los secretos reales.

APP_PREFIX=odmgr
APP_DOMAIN=odmgr.pepelui.es
APP_PORT=8000
NGINX_PORT=8080
POSTGRES_PORT=5432
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=CHANGE_ME
DATABASE_URL=postgresql+psycopg2://CHANGE_ME:CHANGE_ME@db:5432/CHANGE_ME
DB_HOST=db
DB_PORT=5432
DB_USER=CHANGE_ME

# OSM / Overpass
OVERPASS_LOCAL_URL=http://overpass/api/interpreter
OVERPASS_PLANET_URL=https://download.geofabrik.de/europe/spain-latest.osm.pbf

# Limites de recursos del backend
APP_MEMORY_LIMIT=1g
APP_MEMORY_RESERVATION=256m
APP_CPU_LIMIT=2.0

# Traefik
TRAEFIK_CERTRESOLVER=letsencrypt
