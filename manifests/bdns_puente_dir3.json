        {
          "key": "url",
          "value": "https://www.infosubvenciones.es/bdnstrans/api/organos/codigo",
          "is_external": false
        },
        {
          "key": "request",
          "value": "query",
          "is_external": false
        },
        {
          "key": "pagination",
          "value": "pivot_loop",
          "is_external": false
        },
        {
          "key": "pivot_param",
          "value": "codigo",
          "is_external": false
        },
        {
          "key": "pivot_field_out",
          "value": "dir3",
          "is_external": false
        },
        {
          "key": "pivot_source_resource",
          "value": "DIR3 - Unidades Organicas (XLSX)",
          "is_external": false
        },
        {
          "key": "pivot_source_field",
          "value": "C_ID_UD_ORGANICA",
          "is_external": false
        },
        {
          "key": "query_params",
          "value": "{\"vpd\": \"GE\"}",
          "is_external": false
        },
        {
          "key": "dedup_key",
          "value": "dir3",
          "is_external": false
        },
        {
          "key": "dedup_order_field",
          "value": "dir3",
          "is_external": false
        },
        {
          "key": "delay",
          "value": "0.3",
          "is_external": false
        },
        {
          "key": "timeout",
          "value": "30",
          "is_external": false
        }
      ]
    }
  ]
