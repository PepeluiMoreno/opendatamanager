# full database url
DATABASE_URL=postgresql+psycopg2://odmgr_admin:Q7v%21p2rX9eZs4%40tL@db:5432/odmgr_db

# api graphql backend
API_HOST=localhost
API_PORT=8040
API_URL=http://localhost:8002/graphql

# frontend (compartido con vite)
VITE_API_URL=http://localhost:8002/graphql
VITE_GRAPHQL_URL=http://localhost:8002/graphql

# Prefijo para nombres de contenedores Docker
APP_PREFIX=odmgr

# Puertos para stack Docker
APP_PORT=8002
NGINX_PORT=80
FRONTEND_PORT=5173
POSTGRES_PORT=55432

# Credenciales y nombre de base de datos para stack Docker
POSTGRES_USER=odmgr_admin
POSTGRES_PASSWORD=Q7v!p2rX9eZs4@tL
POSTGRES_DB=odmgr_db

# ── Límites de contenedores ───────────────────────────────────────────────────
# app      ≈ 15 % de la RAM del host
APP_MEMORY_LIMIT=1g
APP_MEMORY_RESERVATION=256m
APP_CPU_LIMIT=2.0
# overpass → sin límite de contenedor; el entrypoint autodetecta la RAM
#            y calcula --flush-size = RAM_total / 2

# ── OSM / Overpass ────────────────────────────────────────────────────────────
OVERPASS_LOCAL_URL=http://overpass/api/interpreter
OVERPASS_PLANET_URL=https://download.geofabrik.de/europe/spain-latest.osm.pbf


